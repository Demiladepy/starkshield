{
  "name": "@fatsolutions/she",
  "version": "0.4.0",
  "description": "Homomorphic Encryption over the Stark curve",
  "homepage": "https://github.com/fatlabsxyz/she",
  "repository": {
    "type": "git",
    "url": "https://github.com/fatlabsxyz/she.git",
    "directory": "packages/she"
  },
  "author": {
    "name": "Fat Solutions",
    "email": "root@fatlabs.xyz",
    "url": "https://fatsolutions.xyz/"
  },
  "keywords": [
    "starknet",
    "homomorphic",
    "elgamal"
  ],
  "files": [
    "lib/*",
    "src",
    "package.json",
    "!**/*.tsbuildinfo"
  ],
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "require": "./lib/index.js"
    },
    "./protocols": {
      "types": "./lib/protocols.d.ts",
      "import": "./lib/protocols.js",
      "require": "./lib/protocols.js"
    }
  },
  "dependencies": {
    "@noble/ciphers": "1.3.0",
    "@noble/curves": "1.7.0",
    "@noble/hashes": "1.8.0",
    "@scure/base": "1.2.5",
    "@scure/starknet": "1.1.0"
  },
  "devDependencies": {
    "vitest": "3.0.5"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "clean": "rm -rf lib",
    "build": "tsc -p ./tsconfig.json --outDir lib",
    "test": "vitest run --testTimeout 0 --config vitest.config.ts --passWithNoTests",
    "lint": "eslint --config ../../eslint.config.mjs \"{src,test}/**/*.{js,ts,json}\"",
    "lint:fix": "eslint --config ../../eslint.config.mjs \"{src,test,tests}/**/*.{js,ts,json}\" --fix",
    "format": "prettier --check \"{src,test}/**/*.{js,ts,json}\"",
    "format:fix": "prettier --write \"{src,test,tests}/**/*.{js,ts,json}\""
  }
}